Algoritmo Calcular_consumo_gasolina
	Definir Kilometros Como Real
	Definir gasolina Como Real
	Definir consumo Como  real 
	Escribir "ingrese los kilometros recorridos: "
	Leer Kilometros 
	Escribir "ingrese los litros de gasolina consumidos: "
	Leer gasolina
	consumo<-Kilometros / gasolina
	Escribir "el consumo de gasolina es:" consumo," km/l";
	
	
FinAlgoritmo
