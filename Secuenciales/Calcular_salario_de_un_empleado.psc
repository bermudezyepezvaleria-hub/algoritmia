Algoritmo Calcular_salario_de_un_empleado
	Definir Horas Como Entero;
	Definir valorhora Como Real; 
	Definir salario Como Real;
	Escribir" Ingrese el numero de horas trabajadas: ";
	Leer Horas;
	Escribir" ingrese el valorhora: ";
	Leer valorhora;
	salario <- Horas*valorhora;
	Escribir" E valor de su salario es:", salario;
	
	
FinAlgoritmo
